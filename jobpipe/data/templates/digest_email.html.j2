<!DOCTYPE html>
<html>
<head>
<meta charset="utf-8">
<style>
  body { font-family: Arial, sans-serif; font-size: 14px; color: #222; }
  h1 { font-size: 18px; border-bottom: 2px solid #333; padding-bottom: 6px; }
  h2 { font-size: 15px; color: #444; margin-top: 20px; }
  table { border-collapse: collapse; width: 100%; margin-top: 10px; }
  th { background: #f0f0f0; text-align: left; padding: 6px 10px; font-size: 13px; }
  td { padding: 6px 10px; border-bottom: 1px solid #e0e0e0; vertical-align: top; }
  .score-high { color: #1a7a1a; font-weight: bold; }
  .score-mid  { color: #a05000; font-weight: bold; }
  .reason     { color: #555; font-style: italic; font-size: 13px; }
  .footer     { margin-top: 30px; font-size: 12px; color: #888; }
</style>
</head>
<body>
<h1>JobPipe Digest — {{ date }} ({{ candidate_name }})</h1>
<p>{{ matches|length }} new match{{ 'es' if matches|length != 1 else '' }} above threshold.</p>

{% if matches %}
<table>
  <thead>
    <tr>
      <th>Score</th>
      <th>Company</th>
      <th>Title</th>
      <th>Location</th>
      <th>Reason</th>
      <th>Links</th>
    </tr>
  </thead>
  <tbody>
  {% for m in matches %}
    <tr>
      <td class="{{ 'score-high' if m.score >= 85 else 'score-mid' }}">{{ m.score }}</td>
      <td>{{ m.company }}</td>
      <td>{{ m.title }}</td>
      <td>{{ m.location or '' }}</td>
      <td class="reason">{{ m.reason }}</td>
      <td>
        <a href="{{ m.jd_url }}">JD</a>
        {% if m.draft_path %} | <code>{{ m.draft_path }}</code>{% endif %}
      </td>
    </tr>
  {% endfor %}
  </tbody>
</table>
{% endif %}

<div class="footer">Generated by JobPipe &mdash; review all drafts before submitting.</div>
</body>
</html>
