# Copy to .env and fill in real values. Never commit .env to the repo.

# Anthropic API key for LLM scoring and tailoring
ANTHROPIC_API_KEY=sk-ant-...

# SQLite (default) or swap to Postgres:
# DATABASE_URL=postgresql+psycopg2://user:pass@localhost:5432/jobpipe
DATABASE_URL=sqlite:///./data/jobpipe.db

# SMTP credentials for email digest
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# Override config directory location (optional)
# CONFIG_DIR=/app/config
